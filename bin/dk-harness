#!/usr/bin/env python3

from __future__ import annotations

import argparse
import subprocess
import sys
from pathlib import Path

from dk_harness_compose import compose_scaffold, load_module_definitions, parse_module_specs


def init_git_repo(destination: Path) -> None:
    subprocess.run(
        ["git", "init", "-b", "main"],
        check=True,
        cwd=destination,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def print_module_list(definitions: dict[str, object]) -> None:
    print("Available modules:")
    for name in sorted(definitions):
        definition = definitions[name]
        requires = ", ".join(definition.requires) if definition.requires else "none"
        conflicts = ", ".join(definition.conflicts) if definition.conflicts else "none"
        repeatable = "yes" if definition.repeatable else "no"
        print(f"- {definition.name}: {definition.documentation['app_summary']}")
        print(f"  kind:            {definition.kind}")
        print(f"  runtime:         {definition.runtime}")
        print(f"  repeatable:      {repeatable}")
        print(f"  requires:        {requires}")
        print(f"  conflicts:       {conflicts}")
        if definition.default_app_id:
            print(f"  default app id:  {definition.default_app_id}")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="dk-harness",
        description="Compose projects from the local harness module catalog.",
    )
    subparsers = parser.add_subparsers(dest="command")

    subparsers.add_parser("list", help="List available scaffold modules.")

    new_parser = subparsers.add_parser("new", help="Create a new project from selected modules.")
    new_parser.add_argument("destination")
    new_parser.add_argument(
        "--module",
        action="append",
        dest="modules",
        default=[],
        help="Module spec in the form <module> or <module>:<app-id>. Repeat the flag to compose multiple modules.",
    )
    new_parser.add_argument("--force", action="store_true")
    new_parser.add_argument("--init-git", action="store_true")

    export_parser = subparsers.add_parser(
        "export",
        help="Compose a scaffold into another directory, useful for syncing standalone generated fixtures.",
    )
    export_parser.add_argument("destination")
    export_parser.add_argument(
        "--module",
        action="append",
        dest="modules",
        default=[],
        help="Module spec in the form <module> or <module>:<app-id>. Repeat the flag to compose multiple modules.",
    )
    export_parser.add_argument("--force", action="store_true")

    return parser


def run_new(
    definitions: dict[str, object],
    destination: str,
    *,
    module_specs: list[str],
    force: bool,
    init_git: bool,
) -> int:
    target = Path(destination).resolve()
    instances = parse_module_specs(module_specs, definitions)
    compose_scaffold(instances, target, force=force)

    if init_git:
        init_git_repo(target)

    print(f"Created {target} from module composition.")
    if init_git:
        print("Initialized a new git repository.")
    return 0


def run_export(
    definitions: dict[str, object],
    destination: str,
    *,
    module_specs: list[str],
    force: bool,
) -> int:
    target = Path(destination).resolve()
    instances = parse_module_specs(module_specs, definitions)
    compose_scaffold(instances, target, force=force)
    print(f"Exported module composition to {target}.")
    return 0


def main(argv: list[str]) -> int:
    definitions = load_module_definitions()
    parser = build_parser()

    args = parser.parse_args(argv[1:])

    if args.command == "list":
        print_module_list(definitions)
        return 0

    if args.command == "new":
        return run_new(
            definitions,
            args.destination,
            module_specs=args.modules,
            force=args.force,
            init_git=args.init_git,
        )

    if args.command == "export":
        return run_export(
            definitions,
            args.destination,
            module_specs=args.modules,
            force=args.force,
        )

    parser.print_help()
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv))
