{
  "name": "dk-harness",
  "version": "0.3.0",
  "description": "Compose Next.js apps, UI kit packages, FastAPI services, and Axum services from the dk-harness module catalog.",
  "keywords": [
    "scaffold",
    "template",
    "cli",
    "nextjs",
    "ui-kit",
    "fastapi",
    "axum"
  ],
  "homepage": "https://github.com/DongkuKim/dk-harness#readme",
  "bugs": {
    "url": "https://github.com/DongkuKim/dk-harness/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DongkuKim/dk-harness.git"
  },
  "bin": {
    "dk-harness": "bin/dk-harness"
  },
  "scripts": {
    "repo:self-check": "node ./scripts/repo-self-check.mjs",
    "repo:supply-chain": "node ./scripts/repo-supply-chain.mjs",
    "modules:check": "node ./scripts/validate-modules.mjs",
    "docs:check": "node ./scripts/docs-check.mjs",
    "fixtures:check": "node ./scripts/generate-scaffolds.mjs",
    "fixtures:sync": "node ./scripts/generate-scaffolds.mjs --write",
    "scaffold:eval": "node ./scripts/scaffold-eval.mjs",
    "release:check": "node ./scripts/release-pack-check.mjs"
  },
  "files": [
    "bin",
    "templates",
    "README.md"
  ],
  "packageManager": "pnpm@9.15.9",
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0"
}
