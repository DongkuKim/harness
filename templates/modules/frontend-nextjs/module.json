{
  "name": "frontend-nextjs",
  "kind": "app",
  "runtime": "node",
  "repeatable": false,
  "default_app_id": "web",
  "requires": [
    "core-monorepo"
  ],
  "conflicts": [],
  "emits": [
    {
      "source": "files/app",
      "target": "apps/web"
    }
