{
  "name": "admin-api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "uv run fastapi dev app/main.py --host 0.0.0.0 --port 8000",
    "build": "uv run python -m compileall app",
    "lint": "uv run ruff check . && uv run deptry . && uv run lint-imports",
    "format": "uv run ruff format .",
    "typecheck": "uv run basedpyright",
    "test": "uv run python -m pytest -n auto",
    "supply-chain": "uv run pip-audit"
  }
}
